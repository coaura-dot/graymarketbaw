<div class="painel produto-detalhe">
  <div class="produto-detalhe-imagem">
    <img src="/images/itens/<%= icone_produto(@produto) %>.png" alt="<%= @produto.nome %>">
  </div>
  <div class="produto-detalhe-info">
  <% if @produto.categoria %>
    <span class="categoria-tag"><%= @produto.categoria %></span>
  <% end %>
  <h1><%= @produto.nome %></h1>
  <p><%= @produto.descricao %></p>
  <p class="preco">R$<%= formatar_preco(@produto.preco) %></p>
  <p>Estoque disponível: <strong><%= @produto.estoque %></strong></p>
  <p>Vendido por: <strong><%= @produto.vendedor.nome %></strong></p>

  <% if logado? %>
    <% if @produto.disponivel? %>
      <form action="/carrinho/<%= @produto.id %>" method="post">
        <div class="form-grupo" style="max-width:140px;">
          <label for="quantidade">Quantidade</label>
          <input type="number" id="quantidade" name="quantidade" value="1" min="1" max="<%= @produto.estoque %>">
        </div>
        <button type="submit" class="botao">Adicionar ao carrinho</button>
      </form>
    <% else %>
      <p class="estoque-baixo">Produto sem estoque no momento.</p>
    <% end %>
  <% else %>
    <p><a href="/login">Entre na sua conta</a> para comprar este item.</p>
  <% end %>

  <p style="margin-top:16px;"><a href="/">&larr; Voltar à loja</a></p>
  </div>
</div>
