<h1>Editar Produto</h1>

<div class="painel" style="max-width:520px;">
  <% if @produto.errors.any? %>
    <div class="erros-lista">
      <ul>
        <% @produto.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <form action="/produtos/<%= @produto.id %>" method="post">
    <div class="form-grupo">
      <label for="nome">Nome</label>
      <input type="text" id="nome" name="nome" value="<%= @produto.nome %>" required>
    </div>
    <div class="form-grupo">
      <label for="descricao">Descrição</label>
      <textarea id="descricao" name="descricao" rows="3"><%= @produto.descricao %></textarea>
    </div>
    <div class="form-grupo">
      <label for="categoria">Categoria</label>
      <select id="categoria" name="categoria">
        <% Produto::CATEGORIAS.each do |cat| %>
          <option value="<%= cat %>" <%= "selected" if @produto.categoria == cat %>><%= cat %></option>
        <% end %>
      </select>
    </div>
    <div class="form-grupo">
      <label for="preco">Preço ($)</label>
      <input type="number" step="0.01" min="0.01" id="preco" name="preco" value="<%= @produto.preco %>" required>
    </div>
    <div class="form-grupo">
      <label for="estoque">Estoque</label>
      <input type="number" min="0" id="estoque" name="estoque" value="<%= @produto.estoque %>" required>
    </div>
    <button type="submit" class="botao">Salvar alterações</button>
  </form>
</div>
